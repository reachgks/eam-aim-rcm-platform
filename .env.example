# ============================================================
# EAM/AIM/RCM Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# --------------------------------------------------
# General
# --------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# --------------------------------------------------
# Database — PostgreSQL + TimescaleDB
# --------------------------------------------------
DATABASE_URL=postgresql://eamaim:eamaim_secret@localhost:5432/eamaim_dev?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --------------------------------------------------
# Redis
# --------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --------------------------------------------------
# Authentication — JWT
# --------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --------------------------------------------------
# API Server
# --------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_PREFIX=/api/v1

# --------------------------------------------------
# Web App (Next.js)
# --------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --------------------------------------------------
# MQTT — IoT Telemetry Broker
# --------------------------------------------------
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=eamaim
MQTT_PASSWORD=mqtt_secret
MQTT_CLIENT_ID=eamaim-api
MQTT_TOPIC_PREFIX=eamaim/telemetry

# --------------------------------------------------
# Telemetry Processing
# --------------------------------------------------
TELEMETRY_BATCH_SIZE=500
TELEMETRY_FLUSH_INTERVAL=5000
TELEMETRY_RETENTION_DAYS=365

# --------------------------------------------------
# CORS
# --------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# --------------------------------------------------
# Email — SMTP
# --------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eamaim.local
SMTP_SECURE=false

# --------------------------------------------------
# Object Storage — S3 / MinIO
# --------------------------------------------------
S3_BUCKET=eamaim-assets
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --------------------------------------------------
# PgAdmin
# --------------------------------------------------
PGADMIN_EMAIL=admin@eamaim.local
PGADMIN_PASSWORD=pgadmin_secret
PGADMIN_PORT=5050

# --------------------------------------------------
# Error Tracking — Sentry
# --------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# --------------------------------------------------
# BIM / IFC Processing
# --------------------------------------------------
IFC_WORKER_CONCURRENCY=2
IFC_MAX_FILE_SIZE_MB=500
IFC_STORAGE_PATH=./uploads/ifc

# --------------------------------------------------
# Session & Security
# --------------------------------------------------
SESSION_SECRET=change-me-session-secret
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
